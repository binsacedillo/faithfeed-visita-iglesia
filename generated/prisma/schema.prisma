generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = "file:./db.sqlite"
}

model Post {
  id             String   @id @default(cuid())
  type           String
  title          String
  content        String
  author         String?
  scriptureRef   String?
  imageUrl       String?
  stationNumber  Int?
  prayerText     String?
  prayerResponse String?
  introText      String?
  outroText      String?
  category       String   @default("GENERAL")
  scheduledDay   String?
  closingPrayer  Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([type])
  @@index([category])
}
